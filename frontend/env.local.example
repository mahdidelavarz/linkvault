# ─── Local Development Setup ──────────────────────────────────────────────────
#
# Copy this file to .env.local to develop the frontend locally against the
# production backend without running Docker.
#
#   cp env.local.example .env.local
#   npm install
#   npm run dev
#
# HOW IT WORKS
# ────────────
# The Next.js dev server rewrites every /api/* request to BACKEND_INTERNAL_URL.
# Your browser sends requests to localhost:3000/api/... — Next.js proxies them
# server-side to the production backend. CORS is not involved because the proxy
# is server-to-server.
#
# DO NOT set NEXT_PUBLIC_API_URL here. Leave it unset so http.ts defaults to
# the relative "/api" path and the Next.js proxy handles the forwarding.

# Production backend to proxy /api/* requests to during local development.
BACKEND_INTERNAL_URL=https://neovault.ir

# OPTIONAL: If your local machine is on a LAN and you want phones/tablets on
# the same network to access the dev server with HMR, add your machine's LAN
# IP to `allowedDevOrigins` in next.config.ts. The current value is 192.168.1.100.
